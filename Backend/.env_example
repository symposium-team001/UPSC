# Application
NODE_ENV=development
PORT=5000

# Database & Redis
MONGO_URI=mongodb://localhost:27017/upsc_backend
REDIS_URL=redis://localhost:6379

# JWT Secrets (Min 32 chars)
JWT_ACCESS_SECRET=your_32_chars_long_access_secret_here
JWT_REFRESH_SECRET=your_32_chars_long_refresh_secret_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Auth & Security
BCRYPT_ROUNDS=10
COOKIE_SECRET=your_32_chars_long_cookie_secret_here
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# OTP Configuration
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
OTP_RATE_LIMIT_MAX=5

# Third Party Services
RESEND_API_KEY=re_xxx
FCM_SERVER_KEY=xxx
RAZORPAY_KEY_ID=xxx
RAZORPAY_KEY_SECRET=xxx
